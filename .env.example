# Copy this file to .env and fill in real values. Never commit .env.
# This template is safe to commit. Real keys go in .env, never here.

# Composio API key from https://app.composio.dev/ (Settings > API Keys)
COMPOSIO_API_KEY=

# Anthropic API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: path to Google OAuth credentials if you ever use the local MCP route
# GOOGLE_OAUTH_CREDENTIALS=C:\Users\alexa\.google-mcp\gcp-oauth.keys.json

# Optional: Google Maps API key from Google Cloud Console (Directions API enabled).
# Required only if /calendar-prep should compute drive times instead of estimating.
GOOGLE_MAPS_API_KEY=

# Optional: Voyage AI API key for vector embeddings in tools/retrieval.mjs.
# Without it, retrieval falls back to BM25-only (still works well for the
# context library size). Get a key at https://www.voyageai.com.
# VOYAGE_MODEL defaults to voyage-3-lite (cheap). Override if you want.
VOYAGE_API_KEY=
# VOYAGE_MODEL=voyage-3-lite

# Optional: model overrides for tools/think.mjs and the optional rerank in
# tools/retrieval.mjs. Defaults are sane; only set these if you want to
# pin a specific model.
# ANTHROPIC_THINK_MODEL=claude-sonnet-4-6
# ANTHROPIC_RERANK_MODEL=claude-haiku-4-5-20251001

# email-drafter delivers drafts to your own inbox via SMTP. The recipient is locked
# to SELF_EMAIL at the script level (see send-to-self.mjs), so the agent cannot
# email third parties through this path.
SELF_EMAIL=your-email@example.com

# SMTP for send-to-self.mjs. If you are already running role-radar in a sibling
# directory, you can leave these blank; the script falls back to
# ../role-radar/.env (ROLE_RADAR_SMTP_*). Otherwise set them here.
# For Gmail, host=smtp.gmail.com, port=587, password = an App Password from
# https://myaccount.google.com/security (not your real Gmail password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Forwarding-address inbound channel. See FORWARD_SETUP.md. Anything POSTed to
# /api/forward with a matching X-Forward-Secret header becomes a queue item.
# Leave blank for local-only soft mode (no auth).
FORWARD_SECRET=

# Slack thread-native surface. See SLACK_SETUP.md.
# Signing secret from your Slack app's Basic Information page. If set,
# /api/slack/event verifies every request signature. Leave blank for local dev.
SLACK_SIGNING_SECRET=
# Bot User OAuth token (xoxb-...) from OAuth & Permissions. Required for thread
# replies via chat.postMessage. Leave blank to use the incoming-webhook fallback.
SLACK_BOT_TOKEN=
# Optional incoming-webhook URL. Channel-only broadcast, no threading. Fallback
# if SLACK_BOT_TOKEN is not set.
SLACK_WEBHOOK_URL=
